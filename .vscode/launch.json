{
    "version": "0.2.0",
    "configurations": [
                {
            "name": "Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Collect Senatsprotokille Imgs",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/data_collection/senatsprotokolle_collection/image_scraping.py",
            "console": "integratedTerminal",
            "args": ["-m", "data/raw_data/UGreifswald Senatsprotokolle/Protokolle_1799/METS.xml",
                     "-o", "data/raw_data/UGreifswald Senatsprotokolle/Protokolle_1799/images"]
        },
        {
            "name": "Generate Synthetic Text Images",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/data_collection/synthetic_text_generation/text_generator.py",
            "console": "integratedTerminal",
            "args": ["--texts", "data/synthetic_texts.txt",
                     "--output", "data/synthetic_data",
                     "--count", "1",
                     "--font-size", "50"],
            "justMyCode": false
        },
        {
            "name": "Clean German Correspondance Book",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/data_collection/synthetic_text_generation/prepare_texts.py",
            "console": "integratedTerminal",
            "args": ["--input", "data/raw_book_texts.txt",
                     "--output", "data/synthetic_texts.txt",
                     "--segments", "5000"],
            "justMyCode": false
        },
        {
            "name": "Dataset Demo",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/modeling/dataset.py",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Basic Model - Raw Data",
            "type": "debugpy",
            "request": "launch",
            "module": "src.modeling.basic_model",
            "console": "integratedTerminal",
            "args": ["--data", "raw"],
            "justMyCode": false
        },
        {
            "name": "Basic Model - Synthetic Data",
            "type": "debugpy",
            "request": "launch",
            "module": "src.modeling.basic_model",
            "console": "integratedTerminal",
            "args": ["--data", "synthetic"],
            "justMyCode": false
        },
        {
            "name": "Basic Model - Both",
            "type": "debugpy",
            "request": "launch",
            "module": "src.modeling.basic_model",
            "console": "integratedTerminal",
            "args": ["--data", "both"],
            "justMyCode": false
        },
        {
            "name": "Kurrent OCR - Raw Data",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/modeling/training/trocr_kurrent.py",
            "console": "integratedTerminal",
            "args": [
                "--data", "raw",
                "--exclude", "Digitale Schriftkunde Archive Bayerns", "DTA Handwritten OCR", "grandpa_letters_2", "UGreifswald Senatsprotokolle"
            ],
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "env": {"PYTHONPATH": "${workspaceFolder}"}
        },
        {
            "name": "Kurrent OCR - Synthetic Data",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/modeling/training/trocr_kurrent.py",
            "console": "integratedTerminal",
            "args": ["--data", "synthetic"],
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "env": {"PYTHONPATH": "${workspaceFolder}"}
        },
        {
            "name": "Kurrent OCR - Both",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/modeling/training/trocr_kurrent.py",
            "console": "integratedTerminal",
            "args": ["--data", "both"],
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "env": {"PYTHONPATH": "${workspaceFolder}"}
        },
        {
            "name": "Grammar Corrector - Raw Data",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/modeling/training/error_correction.py",
            "console": "integratedTerminal",
            "args": ["--data", "raw",
                     "--exclude", "grandpa_letters_2"],
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "env": {"PYTHONPATH": "${workspaceFolder}/src"}
        },
        {
            "name": "Grammar Corrector - Synthetic Data",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/modeling/training/error_correction.py",
            "console": "integratedTerminal",
            "args": ["--data", "synthetic"],
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "env": {"PYTHONPATH": "${workspaceFolder}/src"}
        },
        {
            "name": "Grammar Corrector - Both",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/modeling/training/error_correction.py",
            "console": "integratedTerminal",
            "args": ["--data", "both"],
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "env": {"PYTHONPATH": "${workspaceFolder}/src"}
        },
        {
            "name": "XML Inference - Path",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/modeling/inference/xml_inference.py",
            "console": "integratedTerminal",
            "args": [
                "--mode", "path",
                "--xml", "data/raw_data/Digitale Schriftkunde Archive Bayerns/xml/Reichsstadt/Reichsstadt_Nuernberg_Ratsverlaesse_443_S70_Jahr_1806.xml",
                "--image", "data/raw_data/Digitale Schriftkunde Archive Bayerns/images/Reichsstadt/Reichsstadt_Nuernberg_Ratsverlaesse_443_S70_Jahr_1806.png",
                "--ocr-model", "models/kurrent_ocr/trocr_both",
                "--corrector-model", "models/grammar_corrector/corrector_both_best"
            ],
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "env": {"PYTHONPATH": "${workspaceFolder}/src"}
        },
        {
            "name": "XML Inference - Dataset",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/modeling/inference/xml_inference.py",
            "console": "integratedTerminal",
            "args": [
                "--mode", "dataset",
                "--data", "both",
                "--split", "test",
                "--ocr-model", "models/kurrent_ocr/trocr_both",
                "--corrector-model", "models/grammar_corrector/corrector_both_best"
            ],
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "env": {"PYTHONPATH": "${workspaceFolder}/src"}
        },
        {
            "name": "OCR Predict",
            "type": "debugpy",
            "request": "launch",
            "module": "src.modeling.ocr_preds",
            "console": "integratedTerminal",
            "args": ["data/raw_data/grandpa_letters/images/0044_Letter 4 March 39 father.jpg"],
            "justMyCode": false
        },
    ]
}